  过程 raiseEIO(msg: string) {.noinline, noreturn.} =
    raise newException(IOError, msg)

  过程 echoBinSafe(args: openArray[string]) {.compilerproc.} =
    when 已定义(androidNDK):
      # when running nim 在 android app, stdout goes nowhere, so 打印 gets ignored
      # To redirect 打印 to the android logcat, use -d:androidNDK
      常量 ANDROID_LOG_VERBOSE = 2.cint
      过程 android_log_print(prio: cint, tag: C字符串, fmt: C字符串): cint
        {.importc: "__android_log_print", header: "<android/log.h>", varargs, discardable.}
      变量 s = ""
      对于 arg 在 args:
        s.add arg
      android_log_print(ANDROID_LOG_VERBOSE, "kl", s)
    否则:
      # flockfile deadlocks some versions 当为 Android 5.x.x
      when stdOutLock:
        过程 flockfile(f: CFilePtr) {.importc, nodecl.}
        过程 funlockfile(f: CFilePtr) {.importc, nodecl.}
        flockfile(cstdout)
      when 已定义(windows) 并且 compileOption("threads"):
        acquireSys echoLock
      对于 s 在 args:
        when 已定义(windows):
          # equivalent to syncio.writeWindows
          过程 writeWindows(f: CFilePtr; s: string; doRaise =  假) =
            
            变量 i = 整数 c_fprintf(f, "%s", s)
            while i < s.len:
              如果 s[i] == '\0':
                让 w = c_fputc('\0', f)
                如果 w != 0:
                  如果 doRaise: raiseEIO("无法将字符串写入文件")
                  break
                inc i
              否则:
                让 w = c_fprintf(f, "%s", unsafeAddr s[i])
                如果 w <= 0:
                  如果 doRaise: raiseEIO("无法将字符串写入文件")
                  break
                inc i, w
          writeWindows(cstdout, s)
        否则:
          忽略 c_fwrite(s.C字符串, 强制类型转换[csize_t](s.len), 1, cstdout)
      常量 linefeed = "\n"
      忽略 c_fwrite(linefeed.C字符串, linefeed.len, 1, cstdout)
      忽略 c_fflush(cstdout)
      when stdOutLock:
        funlockfile(cstdout)
      when 已定义(windows) 并且 compileOption("threads"):
        releaseSys echoLock


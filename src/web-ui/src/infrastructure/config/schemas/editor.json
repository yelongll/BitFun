{
  "version": "1.0",
  "id": "editor",
  "title": "编辑器配置",
  "icon": "edit",
  "description": "代码编辑器外观和行为设置",
  "order": 2,
  "sections": [
    {
      "id": "appearance",
      "title": "外观设置",
      "description": "编辑器的视觉外观配置",
      "fields": [
        {
          "type": "select",
          "dataType": "string",
          "key": "theme",
          "title": "编辑器主题",
          "description": "选择编辑器的色彩主题",
          "default": "vs-dark",
          "ui": {
            "options": [
              {
                "value": "vs",
                "label": "浅色主题",
                "description": "经典的浅色编辑器主题"
              },
              {
                "value": "vs-dark",
                "label": "深色主题",
                "description": "经典的深色编辑器主题"
              },
              {
                "value": "hc-black",
                "label": "高对比度",
                "description": "高对比度黑色主题"
              },
              {
                "value": "github-light",
                "label": "GitHub 浅色",
                "description": "GitHub 风格浅色主题"
              },
              {
                "value": "github-dark",
                "label": "GitHub 深色",
                "description": "GitHub 风格深色主题"
              }
            ]
          }
        },
        {
          "type": "select",
          "dataType": "string",
          "key": "fontFamily",
          "title": "字体",
          "description": "编辑器使用的字体",
          "default": "JetBrains Mono",
          "ui": {
            "options": [
              {
                "value": "JetBrains Mono",
                "label": "JetBrains Mono",
                "description": "专为开发者设计的等宽字体"
              },
              {
                "value": "Fira Code",
                "label": "Fira Code",
                "description": "支持连字的编程字体"
              },
              {
                "value": "Cascadia Code",
                "label": "Cascadia Code",
                "description": "Microsoft 开发的编程字体"
              },
              {
                "value": "Source Code Pro",
                "label": "Source Code Pro",
                "description": "Adobe 开源的等宽字体"
              },
              {
                "value": "Consolas",
                "label": "Consolas",
                "description": "Windows 系统默认编程字体"
              },
              {
                "value": "Monaco",
                "label": "Monaco",
                "description": "macOS 系统经典编程字体"
              }
            ]
          }
        },
        {
          "type": "range",
          "dataType": "number",
          "key": "fontSize",
          "title": "字体大小",
          "description": "编辑器文字的大小",
          "default": 14,
          "ui": {
            "min": 10,
            "max": 24,
            "step": 1,
            "marks": {
              "10": "小",
              "14": "标准",
              "18": "大",
              "24": "超大"
            },
            "showValue": true,
            "suffix": "px"
          },
          "validation": {
            "min": 10,
            "max": 24
          }
        },
        {
          "type": "range",
          "dataType": "number",
          "key": "lineHeight",
          "title": "行高",
          "description": "代码行之间的间距",
          "default": 1.5,
          "ui": {
            "min": 1.0,
            "max": 2.0,
            "step": 0.1,
            "showValue": true
          }
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "fontLigatures",
          "title": "启用字体连字",
          "description": "显示字体连字效果（如 => 显示为箭头）",
          "default": true
        },
        {
          "type": "select",
          "dataType": "string",
          "key": "fontWeight",
          "title": "字体粗细",
          "description": "编辑器文字的粗细程度",
          "default": "normal",
          "ui": {
            "options": [
              {
                "value": "normal",
                "label": "正常",
                "description": "标准字体粗细"
              },
              {
                "value": "bold",
                "label": "粗体",
                "description": "较粗的字体"
              },
              {
                "value": "lighter",
                "label": "细体",
                "description": "较细的字体"
              }
            ]
          }
        },
        {
          "type": "select",
          "dataType": "string",
          "key": "renderLineHighlight",
          "title": "当前行高亮",
          "description": "当前光标所在行的显示方式",
          "default": "line",
          "ui": {
            "options": [
              {
                "value": "line",
                "label": "整行",
                "description": "高亮整行背景"
              },
              {
                "value": "gutter",
                "label": "仅行号",
                "description": "只高亮行号区域"
              },
              {
                "value": "all",
                "label": "全部",
                "description": "高亮整行和行号"
              },
              {
                "value": "none",
                "label": "关闭",
                "description": "不高亮当前行"
              }
            ]
          }
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "scrollBeyondLastLine",
          "title": "滚动到最后一行之后",
          "description": "允许编辑器滚动到最后一行内容之后",
          "default": true
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "semanticHighlighting",
          "title": "语义高亮",
          "description": "根据代码语义进行语法高亮",
          "default": true
        }
      ]
    },
    {
      "id": "guides",
      "title": "参考线",
      "description": "编辑器参考线设置",
      "collapsible": true,
      "collapsed": false,
      "fields": [
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "guides.indentation",
          "title": "缩进参考线",
          "description": "显示垂直的缩进参考线",
          "default": true
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "guides.bracketPairs",
          "title": "括号配对参考线",
          "description": "显示配对的括号之间的参考线",
          "default": true
        },
        {
          "type": "select",
          "dataType": "string",
          "key": "guides.bracketPairsHorizontal",
          "title": "水平括号参考线",
          "description": "水平括号配对参考线的显示方式",
          "default": "active",
          "ui": {
            "options": [
              {
                "value": "active",
                "label": "活动时",
                "description": "只在光标位于括号内时显示"
              },
              {
                "value": "true",
                "label": "总是",
                "description": "始终显示水平参考线"
              },
              {
                "value": "false",
                "label": "关闭",
                "description": "不显示水平参考线"
              }
            ]
          }
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "guides.highlightActiveBracketPair",
          "title": "高亮活动括号对",
          "description": "高亮显示光标所在的括号对",
          "default": true
        },
        {
          "type": "select",
          "dataType": "string",
          "key": "guides.highlightActiveIndentation",
          "title": "高亮活动缩进",
          "description": "高亮显示当前光标所在的缩进级别",
          "default": "always",
          "ui": {
            "options": [
              {
                "value": "always",
                "label": "总是",
                "description": "始终高亮活动缩进"
              },
              {
                "value": "true",
                "label": "默认",
                "description": "默认高亮行为"
              },
              {
                "value": "false",
                "label": "关闭",
                "description": "不高亮活动缩进"
              }
            ]
          }
        }
      ]
    },
    {
      "id": "scrollbar",
      "title": "滚动条",
      "description": "编辑器滚动条设置",
      "collapsible": true,
      "collapsed": true,
      "fields": [
        {
          "type": "select",
          "dataType": "string",
          "key": "scrollbar.vertical",
          "title": "垂直滚动条",
          "description": "垂直滚动条的显示方式",
          "default": "auto",
          "ui": {
            "options": [
              {
                "value": "auto",
                "label": "自动",
                "description": "需要时自动显示"
              },
              {
                "value": "visible",
                "label": "始终显示",
                "description": "始终显示滚动条"
              },
              {
                "value": "hidden",
                "label": "隐藏",
                "description": "不显示滚动条"
              }
            ]
          }
        },
        {
          "type": "select",
          "dataType": "string",
          "key": "scrollbar.horizontal",
          "title": "水平滚动条",
          "description": "水平滚动条的显示方式",
          "default": "auto",
          "ui": {
            "options": [
              {
                "value": "auto",
                "label": "自动",
                "description": "需要时自动显示"
              },
              {
                "value": "visible",
                "label": "始终显示",
                "description": "始终显示滚动条"
              },
              {
                "value": "hidden",
                "label": "隐藏",
                "description": "不显示滚动条"
              }
            ]
          }
        },
        {
          "type": "range",
          "dataType": "number",
          "key": "scrollbar.verticalScrollbarSize",
          "title": "垂直滚动条宽度",
          "description": "垂直滚动条的宽度",
          "default": 10,
          "ui": {
            "min": 5,
            "max": 20,
            "step": 1,
            "showValue": true,
            "suffix": "px"
          }
        },
        {
          "type": "range",
          "dataType": "number",
          "key": "scrollbar.horizontalScrollbarSize",
          "title": "水平滚动条高度",
          "description": "水平滚动条的高度",
          "default": 10,
          "ui": {
            "min": 5,
            "max": 20,
            "step": 1,
            "showValue": true,
            "suffix": "px"
          }
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "scrollbar.useShadows",
          "title": "滚动阴影",
          "description": "在可滚动区域显示阴影效果",
          "default": true
        }
      ]
    },
    {
      "id": "hover",
      "title": "悬停提示",
      "description": "鼠标悬停时的提示设置",
      "collapsible": true,
      "collapsed": true,
      "fields": [
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "hover.enabled",
          "title": "启用悬停提示",
          "description": "鼠标悬停时显示代码提示",
          "default": true
        },
        {
          "type": "number",
          "dataType": "number",
          "key": "hover.delay",
          "title": "悬停延迟",
          "description": "显示悬停提示前的延迟时间",
          "default": 300,
          "ui": {
            "min": 0,
            "max": 2000,
            "step": 100,
            "suffix": "ms"
          }
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "hover.sticky",
          "title": "粘性悬停",
          "description": "鼠标移开后保持提示显示",
          "default": false
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "hover.above",
          "title": "在上方显示",
          "description": "在光标上方显示悬停提示",
          "default": false
        }
      ]
    },
    {
      "id": "suggest",
      "title": "代码建议",
      "description": "代码自动建议的详细设置",
      "collapsible": true,
      "collapsed": true,
      "fields": [
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "suggest.showKeywords",
          "title": "显示关键字",
          "description": "在建议中显示语言关键字",
          "default": true
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "suggest.showSnippets",
          "title": "显示代码片段",
          "description": "在建议中显示代码片段",
          "default": true
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "suggest.preview",
          "title": "预览建议",
          "description": "在编辑器中预览选中的建议",
          "default": true
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "suggest.showInlineDetails",
          "title": "显示内联详情",
          "description": "在建议项中显示额外详情",
          "default": true
        }
      ]
    },
    {
      "id": "inlayHints",
      "title": "内联提示",
      "description": "代码内联提示设置",
      "collapsible": true,
      "collapsed": true,
      "fields": [
        {
          "type": "select",
          "dataType": "string",
          "key": "inlayHints.enabled",
          "title": "内联提示",
          "description": "在代码中显示内联提示",
          "default": "on",
          "ui": {
            "options": [
              {
                "value": "on",
                "label": "开启",
                "description": "始终显示内联提示"
              },
              {
                "value": "off",
                "label": "关闭",
                "description": "不显示内联提示"
              },
              {
                "value": "onUnlessPressed",
                "label": "按住Alt时隐藏",
                "description": "按住Alt键时隐藏提示"
              },
              {
                "value": "offUnlessPressed",
                "label": "按住Alt时显示",
                "description": "按住Alt键时显示提示"
              }
            ]
          }
        },
        {
          "type": "range",
          "dataType": "number",
          "key": "inlayHints.fontSize",
          "title": "提示字体大小",
          "description": "内联提示的字体大小",
          "default": 12,
          "ui": {
            "min": 8,
            "max": 20,
            "step": 1,
            "showValue": true,
            "suffix": "px"
          }
        },
        {
          "type": "select",
          "dataType": "string",
          "key": "inlayHints.fontFamily",
          "title": "提示字体",
          "description": "内联提示使用的字体",
          "default": "",
          "ui": {
            "options": [
              {
                "value": "",
                "label": "继承编辑器字体",
                "description": "使用与编辑器相同的字体"
              },
              {
                "value": "JetBrains Mono",
                "label": "JetBrains Mono"
              },
              {
                "value": "Fira Code",
                "label": "Fira Code"
              },
              {
                "value": "Cascadia Code",
                "label": "Cascadia Code"
              }
            ]
          }
        }
      ]
    },
    {
      "id": "behavior",
      "title": "编辑行为",
      "description": "编辑器的交互行为设置",
      "fields": [
        {
          "type": "number",
          "dataType": "number",
          "key": "tabSize",
          "title": "Tab 大小",
          "description": "Tab 键对应的空格数量",
          "default": 2,
          "ui": {
            "min": 1,
            "max": 8,
            "step": 1
          },
          "validation": {
            "min": 1,
            "max": 8
          }
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "insertSpaces",
          "title": "使用空格替代Tab",
          "description": "按 Tab 键时插入空格而不是制表符",
          "default": true
        },
        {
          "type": "select",
          "dataType": "string",
          "key": "wordWrap",
          "title": "自动换行",
          "description": "长行文本超出编辑器宽度时的换行方式",
          "default": "off",
          "ui": {
            "options": [
              {
                "value": "off",
                "label": "关闭",
                "description": "不自动换行，长行可横向滚动"
              },
              {
                "value": "on",
                "label": "开启",
                "description": "超出编辑器宽度时自动换行"
              },
              {
                "value": "wordWrapColumn",
                "label": "按列数换行",
                "description": "超出指定列数时换行"
              },
              {
                "value": "bounded",
                "label": "自适应换行",
                "description": "取编辑器宽度与换行列数的较小值进行换行"
              }
            ]
          }
        },
        {
          "type": "select",
          "dataType": "string",
          "key": "cursorStyle",
          "title": "光标样式",
          "description": "编辑器光标的显示样式",
          "default": "line",
          "ui": {
            "options": [
              {
                "value": "line",
                "label": "竖线",
                "description": "细竖线光标"
              },
              {
                "value": "block",
                "label": "方块",
                "description": "实心方块光标"
              },
              {
                "value": "underline",
                "label": "下划线",
                "description": "下划线光标"
              },
              {
                "value": "line-thin",
                "label": "细竖线",
                "description": "更细的竖线光标"
              },
              {
                "value": "block-outline",
                "label": "空心方块",
                "description": "空心方块光标"
              }
            ]
          }
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "cursorBlinking",
          "title": "光标闪烁",
          "description": "光标是否闪烁",
          "default": true
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "autoClosingBrackets",
          "title": "自动闭合括号",
          "description": "输入左括号时自动添加右括号",
          "default": true
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "autoClosingQuotes",
          "title": "自动闭合引号",
          "description": "输入引号时自动添加闭合引号",
          "default": true
        }
      ]
    },
    {
      "id": "features",
      "title": "功能特性",
      "description": "编辑器高级功能的开关",
      "collapsible": true,
      "collapsed": false,
      "fields": [
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "minimap",
          "title": "显示缩略图",
          "description": "在编辑器右侧显示代码缩略图",
          "default": true
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "lineNumbers",
          "title": "显示行号",
          "description": "在编辑器左侧显示行号",
          "default": true
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "showWhitespace",
          "title": "显示空白字符",
          "description": "显示空格、制表符等不可见字符",
          "default": false
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "renderIndentGuides",
          "title": "显示缩进参考线",
          "description": "显示垂直的缩进参考线",
          "default": true
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "highlightActiveIndentGuide",
          "title": "高亮当前缩进",
          "description": "高亮显示当前光标所在的缩进级别",
          "default": true
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "bracketPairColorization",
          "title": "括号配对着色",
          "description": "用不同颜色显示配对的括号",
          "default": true
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "smoothScrolling",
          "title": "平滑滚动",
          "description": "启用平滑的滚动动画",
          "default": true
        }
      ]
    },
    {
      "id": "code-assistance",
      "title": "代码辅助",
      "description": "智能代码编辑辅助功能",
      "collapsible": true,
      "collapsed": false,
      "fields": [
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "autoCompletion",
          "title": "自动补全",
          "description": "启用智能代码自动补全",
          "default": true
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "quickSuggestions",
          "title": "快速建议",
          "description": "输入时显示快速建议",
          "default": true
        },
        {
          "type": "number",
          "dataType": "number",
          "key": "quickSuggestionsDelay",
          "title": "建议延迟",
          "description": "显示建议前的延迟时间（毫秒）",
          "default": 300,
          "ui": {
            "min": 0,
            "max": 2000,
            "step": 100,
            "suffix": "ms"
          },
          "conditional": {
            "when": "quickSuggestions",
            "value": true,
            "show": true
          }
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "parameterHints",
          "title": "参数提示",
          "description": "显示函数参数提示",
          "default": true
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "hoverInfo",
          "title": "悬停信息",
          "description": "鼠标悬停时显示详细信息",
          "default": true
        },
        {
          "type": "switch",
          "dataType": "boolean",
          "key": "codeActionsOnSave",
          "title": "保存时代码操作",
          "description": "保存文件时自动执行代码格式化等操作",
          "default": true
        },
        {
          "type": "group",
          "title": "错误检查",
          "ui": {
            "collapsible": true,
            "collapsed": false,
            "border": true
          },
          "fields": [
            {
              "type": "switch",
              "dataType": "boolean",
